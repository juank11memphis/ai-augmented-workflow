{
  "name": "@juancr11/sibu",
  "version": "0.9.3",
  "description": "CLI for setting up a local AI-augmented development workflow.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juank11memphis/ai-augmented-workflow.git"
  },
  "homepage": "https://github.com/juank11memphis/ai-augmented-workflow#readme",
  "bugs": {
    "url": "https://github.com/juank11memphis/ai-augmented-workflow/issues"
  },
  "bin": {
    "sibu": "./bin/sibu.js"
  },
  "files": [
    "bin/sibu.js",
    "bin/entrypoints/",
    "bin/admin/",
    "bin/modules/",
    "bin/shared/",
    "!bin/shared/state.js",
    "!bin/**/*.test.js",
    "!bin/echo.js",
    "templates/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x bin/sibu.js",
    "check": "tsc --noEmit",
    "verify": "pnpm build && pnpm check && pnpm test",
    "admin:changelog": "node ./bin/admin/changelog.js",
    "dev:link": "pnpm install && pnpm build && pnpm link --global",
    "dev:unlink": "pnpm unlink --global sibu",
    "prepack": "pnpm run build",
    "smoke:init": "node ./bin/sibu.js init",
    "test": "pnpm build && node ./scripts/run-tests.mjs",
    "validate:packed-runtime": "node ./scripts/validate-packed-cli-runtime.mjs",
    "validate:doctor-version-advisory": "pnpm build && node ./scripts/validate-doctor-version-advisory.mjs",
    "validate:post-update-doctor-drift": "pnpm build && node ./scripts/validate-post-update-doctor-drift.mjs",
    "validate:release-publish": "pnpm verify && npm pack && pnpm run validate:packed-runtime",
    "validate:release": "pnpm run validate:release-publish && pnpm run validate:doctor-version-advisory && pnpm run validate:post-update-doctor-drift",
    "admin:release": "node ./bin/admin/release.js"
  },
  "keywords": [
    "ai",
    "agents",
    "workflow",
    "cli"
  ],
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "gradient-string": "^3.0.0",
    "ink": "^7.0.0",
    "react": "^19.2.5"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  }
}
