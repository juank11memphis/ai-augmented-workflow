{
  "name": "sibu",
  "version": "0.1.0",
  "description": "CLI for setting up a local AI-augmented development workflow.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juank11memphis/ai-augmented-workflow.git"
  },
  "homepage": "https://github.com/juank11memphis/ai-augmented-workflow#readme",
  "bugs": {
    "url": "https://github.com/juank11memphis/ai-augmented-workflow/issues"
  },
  "bin": {
    "sibu": "./bin/sibu.js"
  },
  "files": [
    "bin/",
    "src/",
    "templates/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x bin/sibu.js",
    "check": "tsc --noEmit",
    "verify": "pnpm build && pnpm check && pnpm test",
    "dev:link": "pnpm install && pnpm build && pnpm link --global",
    "dev:unlink": "pnpm unlink --global sibu",
    "prepack": "pnpm run build",
    "smoke:init": "node ./bin/sibu.js init",
    "test": "pnpm build && node --test bin/shared/catalog.test.js bin/shared/prompts.test.js bin/shared/workflow-targets.test.js bin/shared/workflow-mutation-readiness.test.js bin/features/use-skill/handler.test.js bin/features/stop-managing-file/handler.test.js"
  },
  "keywords": [
    "ai",
    "agents",
    "workflow",
    "cli"
  ],
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "gradient-string": "^3.0.0",
    "ink": "^7.0.0",
    "react": "^19.2.5"
  },
  "type": "module"
}
